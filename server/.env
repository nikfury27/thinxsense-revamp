# thinxsense Chatbot & WhatsApp Escalation Environment Configuration

# 1. Server Configuration
PORT=5000

# 2. Meta WhatsApp App Credentials
# Obtain the App Secret from Meta Developer Dashboard -> App Settings -> Basic
META_APP_SECRET=19731000bb1c245760d99ae1bca8318c

# Obtain the Permanent/Temporary Access Token from Meta Developer Dashboard -> WhatsApp -> API Setup
# Must have permissions: whatsapp_business_messaging, whatsapp_business_management
META_ACCESS_

# Obtain Phone Number ID from Meta Developer Dashboard -> WhatsApp -> API Setup -> "Phone number ID"
META_PHONE_NUMBER_ID=1108439132358345
AGENT_PHONE_NUMBER=whatsapp:+919739497518

# 3. Webhook Token Verification
# Enter this exact same verification token in Meta App Dashboard -> Webhooks configuration
WEBHOOK_VERIFY_TOKEN=thinxsense_token

# 5. Agent Settings
AGENT_NAME=Nikhil
